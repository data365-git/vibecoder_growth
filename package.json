{
  "name": "vibecoder-growth",
  "private": true,
  "version": "0.1.0",
  "description": "Vibecoder Growth & Performance System — Telegram bot + admin UI",
  "scripts": {
    "dev:server": "pnpm --filter @vg/server dev",
    "dev:web": "pnpm --filter @vg/web dev",
    "build": "pnpm --filter @vg/server build",
    "start": "pnpm --filter @vg/server start",
    "db:generate": "pnpm --filter @vg/server db:generate",
    "db:migrate": "pnpm --filter @vg/server db:migrate",
    "seed": "pnpm --filter @vg/server seed"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
